# Core API
NODE_ENV=production
API_PORT=3000
DATABASE_URL=postgresql://user:password@host:5432/dbname
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=replace_with_secure_random_secret
JWT_REFRESH_SECRET=replace_with_secure_random_refresh_secret
JWT_ACCESS_TOKEN_TTL=7d
JWT_REFRESH_TOKEN_TTL=120d
GOOGLE_CLIENT_IDS=

# Security / CORS
CORS_ORIGINS=https://naijaspride.vercel.app
BODY_LIMIT_BYTES=1048576

# Manga sources
MANGA_SOURCES_ENABLED=weebcentral,asura,mangadex
MANGA_DEFAULT_SOURCE=weebcentral
MADARA_SOURCES_JSON=[]
MANGAREADER_SOURCES_JSON=[]
ZEISTMANGA_SOURCES_JSON=[]
WPCOMICS_SOURCES_JSON=[]
MMRCMS_SOURCES_JSON=[]
FLARESOLVERR_URL=http://flaresolverr:8191
FLARESOLVERR_LOG_LEVEL=info
FLARESOLVERR_SESSION_MAX_AGE_MS=1800000
MANGA_SOURCE_HEALTH_CACHE_MS=30000

# Source resilience
MANGA_SOURCE_ASURA_CB_FAILURES=5
MANGA_SOURCE_ASURA_CB_RECOVERY_MS=30000
MANGA_SOURCE_WEEBCENTRAL_CB_FAILURES=5
MANGA_SOURCE_WEEBCENTRAL_CB_RECOVERY_MS=30000

# Optional observability
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_RELEASE=

# Storage backend
# Default backend is GCS. To use Supabase S3, set STORAGE_BACKEND=supabase_s3
STORAGE_BACKEND=gcs
GCS_BUCKET_NAME=naijaspride-content
SUPABASE_S3_ENDPOINT=
SUPABASE_S3_REGION=eu-west-1
SUPABASE_S3_ACCESS_KEY_ID=
SUPABASE_S3_SECRET_ACCESS_KEY=
SUPABASE_S3_BUCKET=

# YouTube API (for importing movies from channels)
# Get your API key from https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=
