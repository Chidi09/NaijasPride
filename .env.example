# =============================================================================
# NaijasPride — Environment Variables Reference
# =============================================================================
# Copy this file to .env for local development.
# Production values are set in DigitalOcean App Platform Dashboard or app.yaml.
#
# Infrastructure:
#   API          → DigitalOcean App Platform
#   Frontend     → Vercel (naijaspride.com)
#   Database     → Supabase PostgreSQL
#   Cache/Queue  → DigitalOcean Managed Valkey (Redis-compatible)
#   Storage      → Cloudflare R2 (media.naijaspride.com via CF Worker)
# =============================================================================

# ── Core ───────────────────────────────────────────────────────────────────────
NODE_ENV=production
# DO App Platform injects PORT automatically. Set this only for local dev.
PORT=3000

# ── Database (Supabase PostgreSQL) ─────────────────────────────────────────────
# PgBouncer pooler URL — use this for all runtime queries
DATABASE_URL="postgresql://postgres.USERNAME:PASSWORD@aws-1-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"
# Direct URL (no pooler) — Prisma migrate deploy uses this
DIRECT_URL="postgresql://postgres.USERNAME:PASSWORD@aws-1-eu-west-1.pooler.supabase.com:5432/postgres?sslmode=require"

# ── Cache / Job Queues (DO Managed Valkey) ─────────────────────────────────────
# DO App Platform auto-injects ${naijaspride-valkey.REDIS_URL} in production.
# For local dev, run: docker run -p 6379:6379 redis:7-alpine
REDIS_URL=redis://localhost:6379

# ── Auth ───────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_secure_random_secret
JWT_REFRESH_SECRET=replace_with_secure_random_refresh_secret
JWT_ACCESS_TOKEN_TTL=7d
JWT_REFRESH_TOKEN_TTL=120d
# Comma-separated Google OAuth client IDs (optional)
GOOGLE_CLIENT_IDS=

# ── Security / CORS ────────────────────────────────────────────────────────────
CORS_ORIGINS=https://naijaspride.com,https://www.naijaspride.com
BODY_LIMIT_BYTES=1048576

# ── Storage (Cloudflare R2) ────────────────────────────────────────────────────
# Dashboard → R2 → Manage R2 API Tokens
STORAGE_BACKEND=r2
S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
S3_REGION=auto
S3_BUCKET=naijaspride
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Public URL — served via Cloudflare Worker (apps/media-worker)
STORAGE_PUBLIC_BASE_URL=https://media.naijaspride.com

# ── Payments (Paystack) ────────────────────────────────────────────────────────
PAYSTACK_SECRET_KEY=sk_live_...
FRONTEND_URL=https://naijaspride.com

# ── External APIs ──────────────────────────────────────────────────────────────
YOUTUBE_API_KEY=
TMDB_API_KEY=

# ── Email (ZeptoMail) ──────────────────────────────────────────────────────────
ZEPTOMAIL_API_KEY=

# ── Manga Sources ──────────────────────────────────────────────────────────────
MANGA_SOURCES_ENABLED=weebcentral,asura,mangadex
MANGA_DEFAULT_SOURCE=weebcentral
MADARA_SOURCES_JSON=[]
MANGAREADER_SOURCES_JSON=[]
ZEISTMANGA_SOURCES_JSON=[]
WPCOMICS_SOURCES_JSON=[]
MMRCMS_SOURCES_JSON=[]
# FlareSolverr — bypasses Cloudflare on scraper manga sources
# Leave blank to disable (MangaDex still works; scraper sources will fail gracefully)
FLARESOLVERR_URL=
FLARESOLVERR_LOG_LEVEL=info
FLARESOLVERR_SESSION_MAX_AGE_MS=1800000
MANGA_SOURCE_HEALTH_CACHE_MS=30000
MANGA_SOURCE_ASURA_CB_FAILURES=5
MANGA_SOURCE_ASURA_CB_RECOVERY_MS=30000
MANGA_SOURCE_WEEBCENTRAL_CB_FAILURES=5
MANGA_SOURCE_WEEBCENTRAL_CB_RECOVERY_MS=30000

# ── Torrent Worker ─────────────────────────────────────────────────────────────
# On DO App Platform, /tmp is writable by the app user. Persistent storage
# is not needed — files are uploaded to R2 then deleted.
TORRENT_DOWNLOAD_DIR=/tmp/naijaspride/torrent-downloads
TORRENT_TRANSCODE_MKV=true
TORRENT_PACKAGE_HLS=true
FFMPEG_PATH=/usr/bin/ffmpeg

# ── Book Auto-Import ───────────────────────────────────────────────────────────
EPUBBOOKS_AUTO_IMPORT_ENABLED=true
EPUBBOOKS_AUTO_IMPORT_INTERVAL_MS=21600000
EPUBBOOKS_AUTO_IMPORT_MAX_BOOKS=8
EPUBBOOKS_AUTO_IMPORT_CONCURRENCY=2

# ── Movie Download URL TTL ─────────────────────────────────────────────────────
MOVIE_DOWNLOAD_URL_TTL_SECONDS=21600

# ── Manga New-Chapter Checker ──────────────────────────────────────────────────
# How often to poll manga sources for new chapters (milliseconds). Default: 1 hour.
NEW_CHAPTER_CHECK_INTERVAL_MS=3600000

# ── Firebase Cloud Messaging (Push Notifications) ─────────────────────────────
# Required for server-side FCM push notification delivery (firebase-admin SDK).
# 1. Go to Firebase Console → Project Settings → Service Accounts
# 2. Click "Generate new private key" → download the JSON file
# 3. Minify the entire JSON and paste it here as a single-line string.
#    Example: FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"naijaspride",...}
# Leave blank to disable push notifications (the service becomes a no-op).
FIREBASE_SERVICE_ACCOUNT_JSON=

# ── Observability (optional) ───────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_RELEASE=
