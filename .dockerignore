.env.local
.env.development
*.local

# OS junk
.DS_Store
Thumbs.db

# Git
.git
.gitignore

# IDE
.vscode
.idea
*.swp
*.swo

# Docs & plans (not needed at runtime)
docs/

# Test output
coverage/
*.log
