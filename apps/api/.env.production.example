# =============================================================================
# NAIJASPRIDE API — PRODUCTION ENVIRONMENT
# DigitalOcean App Platform + Supabase + Cloudflare R2 + DO Managed Valkey
# =============================================================================
#
# HOW TO USE:
#   These values are set in the DigitalOcean App Platform Dashboard:
#   Apps → naijaspride → Settings → App-Level Environment Variables
#
#   SECRET-type values are encrypted at rest and masked in logs.
#   Non-secret values are visible in the Dashboard but not in logs.
#
#   DO auto-injects:
#     PORT                   — bound port for the API container
#     ${naijaspride-valkey.REDIS_URL} — Valkey connection string (set in app.yaml)
#
# Legend:
#   [REQUIRED]  — app will crash without this
#   [SECRET]    — mark as Encrypted in DO dashboard
#   [OPTIONAL]  — has a sensible default or feature is disabled when blank
# =============================================================================

# ── Runtime ───────────────────────────────────────────────────────────────────
NODE_ENV=production                             # [REQUIRED]
# PORT is injected by DO App Platform — do not set manually

# ── Database (Supabase PostgreSQL) ────────────────────────────────────────────
# [REQUIRED] [SECRET] PgBouncer pooler — used by Prisma for all runtime queries
DATABASE_URL="postgresql://postgres.USERNAME:PASSWORD@aws-1-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"
# [REQUIRED] [SECRET] Direct connection (no pooler) — used by Prisma migrate only
DIRECT_URL="postgresql://postgres.USERNAME:PASSWORD@aws-1-eu-west-1.pooler.supabase.com:5432/postgres?sslmode=require"

# ── Cache / Job Queues (DO Managed Valkey) ────────────────────────────────────
# [REQUIRED] [SECRET] In app.yaml this is set to: ${naijaspride-valkey.REDIS_URL}
REDIS_URL="rediss://default:PASSWORD@your-valkey-host.db.ondigitalocean.com:PORT"

# ── Authentication ─────────────────────────────────────────────────────────────
# [REQUIRED] [SECRET] Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="YOUR_64_CHAR_HEX_SECRET_HERE"
JWT_REFRESH_SECRET="YOUR_64_CHAR_HEX_REFRESH_SECRET_HERE"
# [OPTIONAL] Token lifetimes (defaults: 7d / 120d)
JWT_ACCESS_TOKEN_TTL="7d"
JWT_REFRESH_TOKEN_TTL="120d"
# [OPTIONAL] Google OAuth — comma-separated client IDs from Google Cloud Console
GOOGLE_CLIENT_IDS=""

# ── Security / CORS ────────────────────────────────────────────────────────────
# [OPTIONAL] Comma-separated allowed origins (defaults to FRONTEND_URL)
CORS_ORIGINS="https://naijaspride.com,https://www.naijaspride.com"
# [OPTIONAL] Max request body size in bytes (default: 1 MB)
BODY_LIMIT_BYTES="1048576"

# ── Storage (Cloudflare R2) ────────────────────────────────────────────────────
# [REQUIRED] Dashboard: Cloudflare → R2 → Manage R2 API Tokens
STORAGE_BACKEND="r2"
S3_ENDPOINT="https://<account-id>.r2.cloudflarestorage.com"
S3_REGION="auto"
S3_BUCKET="naijaspride"
S3_ACCESS_KEY_ID="your-r2-access-key-id"                   # [SECRET]
S3_SECRET_ACCESS_KEY="your-r2-secret-access-key"           # [SECRET]
# [OPTIONAL] Public URL served via Cloudflare Worker (apps/media-worker)
STORAGE_PUBLIC_BASE_URL="https://media.naijaspride.com"

# ── Payments (Paystack) ────────────────────────────────────────────────────────
# [REQUIRED] [SECRET] Live secret key from Paystack dashboard
PAYSTACK_SECRET_KEY="sk_live_..."
# [REQUIRED] Frontend URL for payment callbacks and email links
FRONTEND_URL="https://naijaspride.com"

# ── External APIs ──────────────────────────────────────────────────────────────
# [OPTIONAL] YouTube Data API v3 key — needed for music features
YOUTUBE_API_KEY=""
# [OPTIONAL] TMDB API key — needed for movie metadata enrichment
TMDB_API_KEY=""
# [OPTIONAL] Legacy TMDB key alias (fallback in metadata.service.ts)
TMDB_KEY=""
# [OPTIONAL] OMDB API key — secondary movie metadata source
OMDB_KEY=""
# [OPTIONAL] OpenSubtitles API key — needed for subtitle search
OPENSUBTITLES_KEY=""

# ── Email (ZeptoMail) ──────────────────────────────────────────────────────────
# [OPTIONAL] [SECRET] ZeptoMail Send API key for transactional emails
ZEPTOMAIL_API_KEY=""

# ── Manga Sources ──────────────────────────────────────────────────────────────
# [OPTIONAL] Comma-separated list of enabled manga sources
MANGA_SOURCES_ENABLED="weebcentral,asura,mangadex"
MANGA_DEFAULT_SOURCE="weebcentral"
MADARA_SOURCES_JSON="[]"
MANGAREADER_SOURCES_JSON="[]"
ZEISTMANGA_SOURCES_JSON="[]"
WPCOMICS_SOURCES_JSON="[]"
MMRCMS_SOURCES_JSON="[]"
# [OPTIONAL] FlareSolverr — bypasses Cloudflare on scraper sources. Leave blank to disable.
FLARESOLVERR_URL=""
FLARESOLVERR_LOG_LEVEL="info"
FLARESOLVERR_SESSION_MAX_AGE_MS="1800000"
MANGA_SOURCE_HEALTH_CACHE_MS="30000"
# [OPTIONAL] Per-source circuit breaker config (failures before open / recovery time)
MANGA_SOURCE_ASURA_CB_FAILURES="5"
MANGA_SOURCE_ASURA_CB_RECOVERY_MS="30000"
MANGA_SOURCE_WEEBCENTRAL_CB_FAILURES="5"
MANGA_SOURCE_WEEBCENTRAL_CB_RECOVERY_MS="30000"

# ── Manga New-Chapter Checker ──────────────────────────────────────────────────
# [OPTIONAL] Poll interval in ms (default: 3600000 = 1 hour)
NEW_CHAPTER_CHECK_INTERVAL_MS="3600000"

# ── Torrent Worker ─────────────────────────────────────────────────────────────
# [OPTIONAL] /tmp is writable on DO containers. Files upload to R2 then delete.
TORRENT_DOWNLOAD_DIR="/tmp/naijaspride/torrent-downloads"
TORRENT_TRANSCODE_MKV="true"
TORRENT_PACKAGE_HLS="true"
FFMPEG_PATH="/usr/bin/ffmpeg"

# ── Torrent Discovery (1337x) ─────────────────────────────────────────────────
# [OPTIONAL] Discovers torrents and creates pending movies for approval.
TORRENT_DISCOVERY_ENABLED="false"
TORRENT_SOURCE_URL="https://www.1377x.to/popular-movies-week"
TORRENT_DISCOVERY_INTERVAL_MS="86400000"
TORRENT_DISCOVERY_STARTUP_DELAY_MS="120000"
TORRENT_DISCOVERY_MAX_ITEMS="8"
TORRENT_DISCOVERY_REQUIRE_APPROVAL="true"
TORRENT_DISCOVERY_REQUEST_TIMEOUT_MS="60000"
TORRENT_DISCOVERY_DRY_RUN="false"
TORRENT_DISCOVERY_FAILURE_THRESHOLD="5"
TORRENT_DISCOVERY_RECOVERY_MS="300000"

# ── Remote Stream Ingest (e.g. Soap2Day mirrors) ────────────────────────────
# [OPTIONAL] Enables resilient extract -> ingest -> re-host workflows.
REMOTE_INGEST_ALLOWED_HOSTS=""
REMOTE_INGEST_WORKER_CONCURRENCY="2"
REMOTE_INGEST_PACKAGE_HLS="true"
REMOTE_INGEST_TMP_DIR="/tmp/naijaspride/remote-ingest"
REMOTE_INGEST_STREAM_GATEWAY="true"
REMOTE_INGEST_JOB_ATTEMPTS="3"
REMOTE_INGEST_JOB_BACKOFF_MS="30000"
SOAP2DAY_ALLOWED_MIRRORS=""

# ── Soap2Day Crawler (scheduled discovery) ────────────────────────────────────
# [OPTIONAL] Crawls Soap2Day listing pages and ingests movies with TMDB covers.
# Set SOAP2DAY_CRAWLER_URLS to comma-separated listing/genre page URLs.
SOAP2DAY_CRAWLER_ENABLED="false"
SOAP2DAY_CRAWLER_URLS=""
SOAP2DAY_CRAWLER_MAX_PER_RUN="5"
SOAP2DAY_CRAWLER_INTERVAL_MS="43200000"
SOAP2DAY_CRAWLER_STARTUP_DELAY_MS="600000"

# ── Book Auto-Library Discovery (1337x + Google Books) ──────────────────────
# [OPTIONAL] Discovers must-have and trending books, then writes pending records.
BOOK_AUTO_LIBRARY_ENABLED="false"
BOOK_AUTO_LIBRARY_SOURCE_URL="https://www.1377x.to"
BOOK_AUTO_LIBRARY_INTERVAL_MS="86400000"
BOOK_AUTO_LIBRARY_STARTUP_DELAY_MS="180000"
BOOK_AUTO_LIBRARY_INCLUDE_MUST_HAVES="true"
BOOK_AUTO_LIBRARY_INCLUDE_TRENDING="true"
BOOK_AUTO_LIBRARY_MAX_TARGETS="24"
BOOK_AUTO_LIBRARY_MAX_MATCHES="8"
BOOK_AUTO_LIBRARY_MIN_SEEDERS="5"
BOOK_AUTO_LIBRARY_INGEST="false"
BOOK_AUTO_LIBRARY_DRY_RUN="true"
BOOK_AUTO_LIBRARY_GOOGLE_QUERIES="subject:fiction bestseller,subject:literary fiction"

# ── Book Auto-Import ───────────────────────────────────────────────────────────
# [OPTIONAL] Auto-import settings for the book-import worker
EPUBBOOKS_AUTO_IMPORT_ENABLED="true"
EPUBBOOKS_AUTO_IMPORT_INTERVAL_MS="21600000"
EPUBBOOKS_AUTO_IMPORT_MAX_BOOKS="8"
EPUBBOOKS_AUTO_IMPORT_CONCURRENCY="2"
EPUBBOOKS_AUTO_IMPORT_CURSOR_KEY=""
EPUBBOOKS_AUTO_IMPORT_SORT=""
BOOK_IMPORT_MAX_RETURN_RESULTS=""
BOOK_IMPORT_WORKER_CONCURRENCY=""
ELSCI_LIGHT_NOVELS_BASE_URL="https://server.elsci.one"
ELSCI_LIGHT_NOVELS_ROOT_PATH="/Officially%20Translated%20Light%20Novels/"
ELSCI_LIGHT_NOVELS_REQUEST_TIMEOUT_MS="60000"

# ── Elsci Light Novels Auto-Import Scheduler ──────────────────────────────────
ELSCI_AUTO_IMPORT_ENABLED=false
ELSCI_AUTO_IMPORT_INTERVAL_MS=21600000
ELSCI_AUTO_IMPORT_STARTUP_DELAY_MS=300000

# ── Movie Download URL TTL ─────────────────────────────────────────────────────
# [OPTIONAL] Presigned URL expiry in seconds (default: 21600 = 6 hours)
MOVIE_DOWNLOAD_URL_TTL_SECONDS="21600"

# ── Firebase Cloud Messaging (Push Notifications) ─────────────────────────────
# [OPTIONAL] [SECRET] Server-side FCM push notification delivery (firebase-admin SDK).
# 1. Firebase Console → Project Settings → Service Accounts
# 2. "Generate new private key" → download JSON
# 3. Minify to single-line and paste here.
# Leave blank to disable push notifications (service becomes a no-op).
FIREBASE_SERVICE_ACCOUNT_JSON=

# ── Observability (optional) ───────────────────────────────────────────────────
# [OPTIONAL] Sentry DSN for error tracking
SENTRY_DSN=""
SENTRY_ENVIRONMENT="production"
SENTRY_RELEASE=""
