# =============================================================================
# NAIJASPRIDE API — PRODUCTION ENVIRONMENT
# DigitalOcean App Platform + Supabase + Cloudflare R2 + DO Managed Valkey
# =============================================================================
#
# HOW TO USE:
#   These values are set in the DigitalOcean App Platform Dashboard:
#   Apps → naijaspride → Settings → App-Level Environment Variables
#
#   SECRET-type values are encrypted at rest and masked in logs.
#   Non-secret values are visible in the Dashboard but not in logs.
#
#   DO auto-injects:
#     PORT                   — bound port for the API container
#     ${naijaspride-valkey.REDIS_URL} — Valkey connection string (set in app.yaml)
# =============================================================================

# ── Runtime ───────────────────────────────────────────────────────────────────
NODE_ENV=production
# PORT is injected by DO App Platform — do not set this manually in production

# ── Database (Supabase PostgreSQL) ────────────────────────────────────────────
# PgBouncer pooler — used by Prisma for all runtime queries
DATABASE_URL="postgresql://postgres.USERNAME:PASSWORD@aws-1-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"

# Direct connection (no pooler) — used by Prisma migrate deploy only
DIRECT_URL="postgresql://postgres.USERNAME:PASSWORD@aws-1-eu-west-1.pooler.supabase.com:5432/postgres?sslmode=require"

# ── Cache / Job Queues (DO Managed Valkey) ────────────────────────────────────
# In app.yaml this is set to: ${naijaspride-valkey.REDIS_URL}
# DO injects the actual connection string automatically at deploy time.
REDIS_URL="rediss://default:PASSWORD@your-valkey-host.db.ondigitalocean.com:PORT"

# ── Authentication ─────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="YOUR_64_CHAR_HEX_SECRET_HERE"
JWT_REFRESH_SECRET="YOUR_64_CHAR_HEX_REFRESH_SECRET_HERE"
JWT_ACCESS_TOKEN_TTL="7d"
JWT_REFRESH_TOKEN_TTL="120d"

# Google OAuth — comma-separated client IDs from Google Cloud Console
GOOGLE_CLIENT_IDS=""

# ── Security / CORS ────────────────────────────────────────────────────────────
CORS_ORIGINS="https://naijaspride.com,https://www.naijaspride.com"
BODY_LIMIT_BYTES="1048576"

# ── Storage (Cloudflare R2) ────────────────────────────────────────────────────
# Dashboard: Cloudflare → R2 → Manage R2 API Tokens
STORAGE_BACKEND="r2"
S3_ENDPOINT="https://<account-id>.r2.cloudflarestorage.com"
S3_REGION="auto"
S3_BUCKET="naijaspride"
S3_ACCESS_KEY_ID="your-r2-access-key-id"
S3_SECRET_ACCESS_KEY="your-r2-secret-access-key"
# Public URL served via Cloudflare Worker (apps/media-worker)
STORAGE_PUBLIC_BASE_URL="https://media.naijaspride.com"

# ── Payments (Paystack) ────────────────────────────────────────────────────────
PAYSTACK_SECRET_KEY="sk_live_..."
FRONTEND_URL="https://naijaspride.com"

# ── External APIs ──────────────────────────────────────────────────────────────
YOUTUBE_API_KEY=""
TMDB_API_KEY=""

# ── Email (ZeptoMail) ──────────────────────────────────────────────────────────
ZEPTOMAIL_API_KEY=""

# ── Manga Sources ──────────────────────────────────────────────────────────────
MANGA_SOURCES_ENABLED="weebcentral,asura,mangadex"
MANGA_DEFAULT_SOURCE="weebcentral"
MADARA_SOURCES_JSON="[]"
MANGAREADER_SOURCES_JSON="[]"
ZEISTMANGA_SOURCES_JSON="[]"
WPCOMICS_SOURCES_JSON="[]"
MMRCMS_SOURCES_JSON="[]"
# Leave blank if not running a FlareSolverr instance — scraper sources fail gracefully
FLARESOLVERR_URL=""
FLARESOLVERR_LOG_LEVEL="info"
FLARESOLVERR_SESSION_MAX_AGE_MS="1800000"
MANGA_SOURCE_HEALTH_CACHE_MS="30000"
MANGA_SOURCE_ASURA_CB_FAILURES="5"
MANGA_SOURCE_ASURA_CB_RECOVERY_MS="30000"
MANGA_SOURCE_WEEBCENTRAL_CB_FAILURES="5"
MANGA_SOURCE_WEEBCENTRAL_CB_RECOVERY_MS="30000"

# ── Torrent Worker ─────────────────────────────────────────────────────────────
# /tmp is writable on DO App Platform containers. Files are uploaded to R2 then deleted.
TORRENT_DOWNLOAD_DIR="/tmp/naijaspride/torrent-downloads"
TORRENT_TRANSCODE_MKV="true"
TORRENT_PACKAGE_HLS="true"
FFMPEG_PATH="/usr/bin/ffmpeg"

# ── Book Auto-Import ───────────────────────────────────────────────────────────
EPUBBOOKS_AUTO_IMPORT_ENABLED="true"
EPUBBOOKS_AUTO_IMPORT_INTERVAL_MS="21600000"
EPUBBOOKS_AUTO_IMPORT_MAX_BOOKS="8"
EPUBBOOKS_AUTO_IMPORT_CONCURRENCY="2"

# ── Movie Download URL TTL ─────────────────────────────────────────────────────
MOVIE_DOWNLOAD_URL_TTL_SECONDS="21600"

# ── Observability (optional) ───────────────────────────────────────────────────
SENTRY_DSN=""
SENTRY_ENVIRONMENT="production"
