{
  "name": "api",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/app.ts",
    "prebuild": "prisma generate",
    "build": "tsc && tsc-alias",
    "start": "node dist/app.js",
    "worker:book-import": "npm run build && node dist/workers/book-import.worker.js",
    "worker:torrent": "npm run build && node dist/workers/torrent.worker.js",
    "worker:remote-ingest": "npm run build && node dist/workers/remote-ingest.worker.js",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:status": "prisma migrate status",
    "db:seed": "ts-node --transpile-only ../../tools/scripts/seed-plans.ts",
    "security:enable-rls": "node scripts/enable-rls.js",
    "security:check-rls": "node scripts/check-rls.js",
    "movies:normalize-slugs": "node scripts/normalize-movie-slugs.js",
    "test:manga-sources": "npm run build && node --test dist/modules/books/external/epubbooks/epubbooks.test.js dist/modules/books/sources/parsers/html-parsers.test.js dist/modules/books/sources/providers/weebcentral.source.test.js dist/modules/books/sources/providers/asura.source.test.js dist/modules/books/sources/providers/mangabuddy.source.test.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.988.0",
    "@aws-sdk/s3-request-presigner": "^3.988.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/jwt": "^8.0.0",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/swagger": "^8.14.0",
    "@fastify/swagger-ui": "^2.1.0",
    "@naijaspride/types": "*",
    "@naijaspride/validators": "*",
    "@prisma/client": "^5.10.2",
    "axios": "^1.6.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.4.1",
    "cheerio": "^1.2.0",
    "dotenv": "^16.4.5",
    "fastify": "^4.26.2",
    "fastify-type-provider-zod": "^2.1.0",
    "firebase-admin": "^13.6.1",
    "google-auth-library": "^9.15.1",
    "googleapis": "^133.0.0",
    "handlebars": "^4.7.8",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "playwright": "^1.58.2",
    "rss-parser": "^3.13.0",
    "sanitize-html": "^2.11.0",
    "zeptomail": "^5.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.11.24",
    "@types/sanitize-html": "^2.9.5",
    "pino-pretty": "^11.0.0",
    "prisma": "^5.10.2",
    "ts-node-dev": "^2.0.0",
    "tsc-alias": "^1.8.8",
    "typescript": "^5.3.3"
  },
  "optionalDependencies": {
    "webtorrent": "^2.4.10"
  }
}
