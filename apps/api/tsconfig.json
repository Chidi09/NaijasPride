{
  "compilerOptions": {
    "strict": true,
    "esModuleInterop": true,
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@naijaspride/types": ["../../packages/shared-types/src/index.ts"],
      "@naijaspride/validators": ["../../packages/shared-validators/src/index.ts"],
      "@naijaspride/utils": ["../../packages/shared-utils/src/index.ts"]
    }
  },
  "include": ["src/**/*", "../../packages/shared-types/src/**/*", "../../packages/shared-validators/src/**/*", "../../packages/shared-utils/src/**/*"]
}
