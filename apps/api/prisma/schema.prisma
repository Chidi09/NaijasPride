generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL") // Important for Supabase connection pooling
}

// Enums matching Shared Types
enum Quality {
  Q480p  @map("480p")
  Q720p  @map("720p")
  Q1080p @map("1080p")
  Q4K    @map("4K")
}

enum Genre {
  Action
  Comedy
  Drama
  Romance
  Thriller
  Horror
  Documentary
  Nollywood
  Bollywood  // Added Bollywood support
  Yoruba
  Igbo
  Hausa
  Animation
  SciFi      @map("Sci-Fi")
  Family
}

enum ContentStatus {
  active
  pending
  processing
  deleted
}

// Models
model Movie {
  id              String        @id @default(uuid())
  title           String
  slug            String        @unique
  description     String?
  year            Int
  genre           Genre[]
  language        String        @default("English")
  quality         Quality[]
  durationMinutes Int?
  rating          Float?
  imdbId          String?
  tmdbId          Int?
  thumbnailUrl    String?
  coverUrl        String?
  
  // JSON fields for flexible data
  fileUrls        Json          // Record<Quality, string>
  fileSizes       Json          // Record<Quality, number>
  metadata        Json?         // MovieMetadata

  // New Fields for Streaming
  youtubeId       String?
  isStreamOnly    Boolean       @default(false)

  downloadCount   Int           @default(0)
  viewCount       Int           @default(0)
  status          ContentStatus @default(active)
  uploadedBy      String?

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  publishedAt     DateTime?

  // Relations
  watchlistedBy   User[]         @relation("UserWatchlist")
  downloads       Download[]
  watchHistory    WatchHistory[]

  @@index([slug])
  @@index([year])
  @@index([status])
}

// User Roles for Authentication
enum Role {
  USER
  ADMIN
}

// User Model for Authentication
model User {
  id              String         @id @default(uuid())
  email           String         @unique
  password        String         // Hashed password
  name            String?
  role            Role           @default(USER)
  isPremium       Boolean        @default(false)
  
  // Relations
  watchlist       Movie[]        @relation("UserWatchlist")
  downloadHistory Download[]
  watchHistory    WatchHistory[]
  
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

// Download History Model
model Download {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  movie     Movie    @relation(fields: [movieId], references: [id])
  movieId   String
  quality   String
  timestamp DateTime @default(now())
}

// NEW: Track streaming progress
model WatchHistory {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  movie     Movie    @relation(fields: [movieId], references: [id])
  movieId   String
  progress  Int      @default(0) // Seconds watched
  duration  Int      @default(0) // Total duration
  updatedAt DateTime @updatedAt

  @@unique([userId, movieId]) // One entry per user per movie
}

// NEW: Store Admin RSS Feeds (e.g., YTS, Nyaa, Private Trackers)
model RssFeed {
  id          String   @id @default(uuid())
  name        String
  url         String
  lastChecked DateTime @default(now())
  isEnabled   Boolean  @default(true)
}

// Book Model for Library
model Book {
  id            String   @id @default(uuid())
  title         String
  slug          String   @unique
  author        String
  description   String?
  year          Int
  isbn          String?
  coverUrl      String?
  downloadUrl   String?
  fileSize      Int?
  format        String   @default("PDF") // PDF, EPUB, MOBI, etc.
  genre         String[]
  language      String   @default("English")
  pageCount     Int?
  rating        Float?
  publisher     String?
  
  downloadCount Int      @default(0)
  status        ContentStatus @default(active)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@index([slug])
  @@index([year])
}
