generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// Enums matching Shared Types
enum Quality {
  Q480p  @map("480p")
  Q720p  @map("720p")
  Q1080p @map("1080p")
  Q4K    @map("4K")
}

enum Genre {
  Action
  Comedy
  Drama
  Romance
  Thriller
  Horror
  Documentary
  Nollywood
  Bollywood
  Hollywood
  Yoruba
  Igbo
  Hausa
  Animation
  SciFi      @map("Sci-Fi")
  Family
}

enum ContentStatus {
  active
  pending
  processing
  deleted
}

// Music Video Genres
enum MusicGenre {
  Afrobeat
  Afropop
  HipHop    @map("Hip-Hop")
  RAndB     @map("R&B")
  Gospel
  Highlife
  Fuji
  Reggae
  Dancehall
  Jazz
  Soul
  Pop
  Rock
  Amapiano
  Traditional
  Alternative
}

// Music Video Region
enum MusicRegion {
  Nigeria
  Ghana
  SouthAfrica
  Kenya
  Tanzania
  International
}

// User Roles for Authentication
enum Role {
  USER
  ADMIN
}

// Subscription Status
enum SubscriptionStatus {
  active
  inactive
  cancelled
  expired
  past_due
}

// Models
model Movie {
  id              String        @id @default(uuid())
  title           String
  slug            String        @unique
  description     String?
  overview        String?       @db.Text
  tagline         String?
  year            Int
  genre           Genre[]
  language        String        @default("English")
  quality         Quality[]
  durationMinutes Int?
  rating          Float?
  tmdbRating      Float?
  imdbRating      Float?
  rottenTomatoes  String?
  imdbId          String?
  tmdbId          Int?          @unique
  thumbnailUrl    String?
  coverUrl        String?
  posterUrl       String?
  backdropUrl     String?
  trailerUrl      String?
  fileUrls        Json
  fileSizes       Json
  metadata        Json?
  youtubeId       String?
  isStreamOnly    Boolean       @default(false)
  downloadCount   Int           @default(0)
  viewCount       Int           @default(0)
  status          ContentStatus @default(active)
  uploadedBy      String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  publishedAt     DateTime?
  
  // Relations
  watchlistedBy   User[]         @relation("UserWatchlist")
  downloads       Download[]
  watchHistory    WatchHistory[]
  notifications   MovieNotification[]
  offlineSaved    OfflineSavedContent[]
  cast            Cast[]

  @@index([slug])
  @@index([year])
  @@index([status])
}

model Cast {
  id        String @id @default(uuid())
  name      String
  character String?
  photoUrl  String?

  movieId   String
  movie     Movie  @relation(fields: [movieId], references: [id], onDelete: Cascade)

  @@index([movieId])
}

// Plan Model - Corporate Grade Subscriptions
model Plan {
  id            String   @id @default(uuid())
  name          String   // "Mobile", "Standard", "Family"
  slug          String   @unique
  price         Int      // in Naira (e.g. 1000 = ₦1,000)
  currency      String   @default("NGN")
  durationDays  Int      @default(30)
  
  // Feature Flags
  maxScreens    Int      @default(1)
  maxQuality    String   @default("720p") // "480p", "1080p", "4k"
  download      Boolean  @default(true)
  ads           Boolean  @default(true)
  priority      Int      @default(0) // for ordering
  
  users         User[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// User Model for Authentication
model User {
  id            String             @id @default(uuid())
  email         String             @unique
  password      String
  name          String?
  role          Role               @default(USER)
  isPremium     Boolean            @default(false)
  emailVerified Boolean            @default(false)
  isGuest       Boolean            @default(false)
  guestExpiresAt DateTime?
  
  // Email verification
  emailVerificationToken String?
  emailVerificationExpires DateTime?
  
  // Password reset
  passwordResetToken String?
  passwordResetExpires DateTime?
  
  // Subscription Details
  planId        String?
  plan          Plan?              @relation(fields: [planId], references: [id])
  subStatus     SubscriptionStatus @default(inactive)
  subStartDate  DateTime?
  nextBillingDate DateTime?
  
  // Relations
  watchlist            Movie[]       @relation("UserWatchlist")
  downloadHistory      Download[]
  watchHistory         WatchHistory[]
  notifications        MovieNotification[]
  pushTokens           PushNotificationToken[]
  offlineSaved         OfflineSavedContent[]
  bookProgress         BookProgress[]
  bookHighlights       BookHighlight[]
  bookFavorites        BookFavorite[]
  mangaProgress        MangaReadingProgress[]
  mangaFavorites       MangaFavorite[]
  mangaNewChapterChecks MangaNewChapterCheck[]
  offlineMangaChapters OfflineMangaChapter[]
  offlineBooks         OfflineBook[]
  musicHistory         MusicWatchHistory[]
  musicLikes           MusicLike[]
  musicPlaylists       MusicPlaylist[]
  wrappedStats         UserWrappedStats[]

  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  
  @@index([emailVerificationToken])
  @@index([passwordResetToken])
}

// Download History Model
model Download {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  movie     Movie    @relation(fields: [movieId], references: [id])
  movieId   String
  quality   String
  timestamp DateTime @default(now())
}

// Track streaming progress
model WatchHistory {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  movie     Movie    @relation(fields: [movieId], references: [id])
  movieId   String
  progress  Int      @default(0)
  duration  Int      @default(0)
  updatedAt DateTime @updatedAt

  @@unique([userId, movieId])
}

// Notification Logic - "Notify me when available"
model MovieNotification {
  id        String   @id @default(uuid())
  userId    String
  movieId   String
  sent      Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  movie     Movie    @relation(fields: [movieId], references: [id], onDelete: Cascade)

  @@unique([userId, movieId])
  @@index([movieId, sent])
}

// Store per-device FCM tokens for targeted push notifications
model PushNotificationToken {
  id          String   @id @default(uuid())
  userId      String
  token       String   @unique
  platform    String?
  deviceLabel String?
  userAgent   String?
  isActive    Boolean  @default(true)
  lastSeenAt  DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isActive])
}

// Book favorites (user's saved/library books)
model BookFavorite {
  id        String   @id @default(uuid())
  userId    String
  bookId    String
  addedAt   DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  book      Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([userId, bookId])
  @@index([userId, addedAt])
}

// Track which manga chapters a user has seen so we can detect NEW ones
// One row per (user, manga) — stores the latest chapter ID seen so far
model MangaNewChapterCheck {
  id                   String   @id @default(uuid())
  userId               String
  // Full source entity ID: "mangadex:uuid" / "weebcentral:id"
  mangaId              String
  mangaTitle           String
  mangaCoverUrl        String?
  // The chapterId (source entity ID) of the most recently notified chapter
  lastSeenChapterId    String?
  // ISO timestamp of the most recently seen chapter upload
  lastSeenAt           DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, mangaId])
  @@index([userId])
}

// Track content saved for offline viewing (PWA)
model OfflineSavedContent {
  id          String   @id @default(uuid())
  userId      String
  movieId     String
  quality     String   // e.g. "1080p", "720p"
  fileSizeBytes Int?   // stored size in bytes
  savedAt     DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  movie       Movie    @relation(fields: [movieId], references: [id], onDelete: Cascade)

  @@unique([userId, movieId, quality])
  @@index([userId])
}

// Track manga chapters saved for offline reading (PWA)
model OfflineMangaChapter {
  id            String   @id @default(uuid())
  userId        String
  // Full source entity ID: "mangadex:uuid" / "weebcentral:id"
  mangaId       String
  mangaTitle    String
  chapterId     String   // source entity ID
  chapterTitle  String?
  pageCount     Int      @default(0)
  fileSizeBytes Int?
  savedAt       DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, chapterId])
  @@index([userId, mangaId])
}

// Track books saved for offline reading (PWA)
model OfflineBook {
  id            String   @id @default(uuid())
  userId        String
  bookId        String
  fileSizeBytes Int?
  format        String   @default("epub")
  savedAt       DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  book          Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([userId, bookId])
  @@index([userId])
}

// Store Admin RSS Feeds
model RssFeed {
  id          String   @id @default(uuid())
  name        String
  url         String
  lastChecked DateTime @default(now())
  isEnabled   Boolean  @default(true)
}

// Book Model for Library
model Book {
  id            String   @id @default(uuid())
  title         String
  slug          String   @unique
  author        String
  description   String?
  year          Int
  isbn          String?
  coverUrl      String?
  downloadUrl   String?
  fileSize      Int?
  format        String   @default("PDF")
  genre         String[]
  language      String   @default("English")
  pageCount     Int?
  rating        Float?
  publisher     String?
  downloadCount Int      @default(0)
  status        ContentStatus @default(active)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  readProgress  BookProgress[]
  highlights    BookHighlight[]
  favorites     BookFavorite[]
  offlineSaves  OfflineBook[]

  @@index([slug])
  @@index([year])
}

// Track reading progress for books
model BookProgress {
  id        String   @id @default(uuid())
  userId    String
  bookId    String
  page      Int      @default(1)
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  book      Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([userId, bookId])
}

// Book highlights/annotations (per-user)
model BookHighlight {
  id        String   @id @default(uuid())
  userId    String
  bookId    String
  kind      String
  color     String
  cfiRange  String?
  excerpt   String?  @db.Text
  page      Int?
  rect      Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  book      Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@index([userId, bookId])
  @@index([bookId])
}

// Track manga reading progress (for MangaDex chapters)
model MangaReadingProgress {
  id          String   @id @default(uuid())
  userId      String
  mangaId     String   // MangaDex manga ID
  chapterId   String   // MangaDex chapter ID
  pageIndex   Int      @default(0)  // Last read page index
  totalPages  Int      @default(0)
  isCompleted Boolean  @default(false)
  lastReadAt  DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, chapterId])
  @@index([userId, mangaId])
  @@index([userId, lastReadAt])
}

// User's favorite manga (from MangaDex)
model MangaFavorite {
  id          String   @id @default(uuid())
  userId      String
  mangaId     String   // MangaDex manga ID
  title       String
  coverUrl    String?
  status      String?  // ongoing, completed, etc.
  addedAt     DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, mangaId])
  @@index([userId, addedAt])
}

// ─── MUSIC VIDEOS ───────────────────────────────────────────────────────────

model MusicVideo {
  id              String        @id @default(uuid())
  title           String
  slug            String        @unique
  artist          String
  artistSlug      String        // URL-safe artist identifier
  featuring       String[]      // Featured artists
  album           String?
  year            Int
  genre           MusicGenre[]
  region          MusicRegion   @default(Nigeria)
  durationSeconds Int?

  // YouTube
  youtubeId       String        @unique
  channelId       String?       // Source YouTube channel ID
  channelTitle    String?

  // Media
  thumbnailUrl    String?       // YouTube default thumbnail
  hdThumbnailUrl  String?       // maxresdefault

  // Flags
  isOfficial      Boolean       @default(true)   // Official MV vs fan upload
  isExplicit      Boolean       @default(false)

  // Engagement (different from movies — replays matter)
  viewCount       Int           @default(0)       // Incremented on page view
  playCount       Int           @default(0)       // Incremented on actual play
  likeCount       Int           @default(0)       // Cached from MusicLike count
  weeklyPlays     Int           @default(0)       // Reset weekly for trending

  status          ContentStatus @default(active)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  publishedAt     DateTime?     // YouTube publish date

  // Relations
  watchHistory    MusicWatchHistory[]
  likes           MusicLike[]
  playlistItems   MusicPlaylistItem[]

  @@index([artistSlug])
  @@index([genre])
  @@index([region])
  @@index([status, weeklyPlays])
  @@index([status, playCount])
  @@index([status, createdAt])
}

// Per-user play history + replay tracking
model MusicWatchHistory {
  id          String     @id @default(uuid())
  userId      String
  musicId     String
  progressSec Int        @default(0)   // Seconds watched
  completed   Boolean    @default(false)
  playCount   Int        @default(1)   // How many times replayed
  lastPlayedAt DateTime  @default(now())
  updatedAt   DateTime   @updatedAt

  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  music       MusicVideo @relation(fields: [musicId], references: [id], onDelete: Cascade)

  @@unique([userId, musicId])
  @@index([userId, lastPlayedAt])
}

// Likes (one per user per video)
model MusicLike {
  id        String     @id @default(uuid())
  userId    String
  musicId   String
  createdAt DateTime   @default(now())

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  music     MusicVideo @relation(fields: [musicId], references: [id], onDelete: Cascade)

  @@unique([userId, musicId])
  @@index([musicId])
}

// User + curated playlists
model MusicPlaylist {
  id          String              @id @default(uuid())
  userId      String
  title       String
  description String?
  coverUrl    String?
  isPublic    Boolean             @default(false)
  isCurated   Boolean             @default(false) // Admin-curated
  curatedSlug String?             @unique          // URL slug for curated playlists

  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  items       MusicPlaylistItem[]

  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([userId])
  @@index([isCurated])
}

model MusicPlaylistItem {
  id         String        @id @default(uuid())
  playlistId String
  musicId    String
  position   Int           @default(0)
  addedAt    DateTime      @default(now())

  playlist   MusicPlaylist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  music      MusicVideo    @relation(fields: [musicId], references: [id], onDelete: Cascade)

  @@unique([playlistId, musicId])
  @@index([playlistId, position])
}

// Music-specific YouTube channels (separate from movie channels)
model MusicChannel {
  id            String   @id @default(uuid())
  name          String
  channelId     String   @unique
  url           String
  artistName    String?  // Canonical artist name for this channel
  region        MusicRegion @default(Nigeria)
  isActive      Boolean  @default(true)
  lastSyncedAt  DateTime?
  totalVideos   Int      @default(0)
  importedCount Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([isActive])
}

// ─── WRAPPED / STATS ────────────────────────────────────────────────────────

// Stores aggregated Wrapped stats + generated card URLs per user per period
model UserWrappedStats {
  id          String   @id @default(uuid())
  userId      String
  // "2025-01" for monthly, "2025-annual" for annual
  period      String
  statsJson   Json     // WrappedStats object (see wrapped-stats.service.ts)
  cardUrls    Json     // { hero, topMovie, topMusic, topBook, genres, summary }
  generatedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, period])
  @@index([userId])
  @@index([period])
}

// ─── YOUTUBE CHANNELS (MOVIES) ──────────────────────────────────────────────

// YouTube Channels for bulk importing
model YouTubeChannel {
  id            String   @id @default(uuid())
  name          String   // Channel display name
  channelId     String   @unique // YouTube channel ID (UC...)
  url           String   // Original URL provided
  isActive      Boolean  @default(true)
  lastSyncedAt  DateTime?
  totalVideos   Int      @default(0) // Total videos found on channel
  importedCount Int      @default(0) // How many already imported
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([isActive])
}
