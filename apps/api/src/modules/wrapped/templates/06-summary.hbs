<div class="card grad-dark">
  <div class="glow-top-right"></div>
  <div class="glow-bottom-left" style="opacity:0.5;"></div>

  <!-- Logo -->
  <div class="logo-bar">
    <div class="logo-mark">NP</div>
    <span class="logo-text">NaijasPride</span>
    <span class="logo-year">{{periodLabel}}</span>
  </div>

  <div style="flex:1; display:flex; flex-direction:column; padding:60px; gap:48px;">

    <div class="badge" style="align-self:flex-start;">✨ {{periodLabel}} Summary</div>

    <!-- Stats grid -->
    <div style="display:grid; grid-template-columns:1fr 1fr; gap:28px;">
      
      <div style="padding:36px; border:1px solid var(--border); border-radius:20px; background:rgba(18,10,13,0.7); display:flex; flex-direction:column; gap:12px;">
        <span style="font-size:32px;">🎬</span>
        <span class="stat-number" style="font-size:52px;">{{totalMoviesWatched}}</span>
        <span class="stat-label" style="font-size:11px;">Movies watched</span>
        <span style="font-size:13px; color:var(--text-muted); margin-top:4px;">{{totalHours}} hours</span>
      </div>

      <div style="padding:36px; border:1px solid var(--border); border-radius:20px; background:rgba(18,10,13,0.7); display:flex; flex-direction:column; gap:12px;">
        <span style="font-size:32px;">🎵</span>
        <span class="stat-number" style="font-size:52px;">{{totalMusicPlays}}</span>
        <span class="stat-label" style="font-size:11px;">Songs played</span>
        <span style="font-size:13px; color:var(--text-muted); margin-top:4px;">{{musicHours}} hours listened</span>
      </div>

      <div style="padding:36px; border:1px solid var(--border); border-radius:20px; background:rgba(18,10,13,0.7); display:flex; flex-direction:column; gap:12px;">
        <span style="font-size:32px;">📚</span>
        <span class="stat-number" style="font-size:52px;">{{totalBooksRead}}</span>
        <span class="stat-label" style="font-size:11px;">Books read</span>
        <span style="font-size:13px; color:var(--text-muted); margin-top:4px;">{{totalHighlights}} highlights</span>
      </div>

      <div style="padding:36px; border:1px solid var(--border); border-radius:20px; background:rgba(18,10,13,0.7); display:flex; flex-direction:column; gap:12px;">
        <span style="font-size:32px;">🔥</span>
        <span class="stat-number" style="font-size:52px;">{{streak.longestStreak}}</span>
        <span class="stat-label" style="font-size:11px;">Day streak</span>
        <span style="font-size:13px; color:var(--text-muted); margin-top:4px;">{{streak.totalActiveDays}} active days</span>
      </div>

    </div>

    <!-- Top items mini -->
    <div style="display:flex; gap:24px;">
      {{#if topMovie}}
      <div style="flex:1; padding:24px; border:1px solid var(--border); border-radius:16px; background:rgba(18,10,13,0.5);">
        <p style="font-size:11px; font-weight:600; color:var(--text-muted); letter-spacing:0.15em; text-transform:uppercase; margin-bottom:8px;">Top Movie</p>
        <p style="font-family:'Cinzel',serif; font-size:18px; font-weight:700; color:var(--text-primary); line-height:1.3;">{{topMovie.title}}</p>
      </div>
      {{/if}}
      {{#if topArtist}}
      <div style="flex:1; padding:24px; border:1px solid var(--border); border-radius:16px; background:rgba(18,10,13,0.5);">
        <p style="font-size:11px; font-weight:600; color:var(--text-muted); letter-spacing:0.15em; text-transform:uppercase; margin-bottom:8px;">Top Artist</p>
        <p style="font-family:'Cinzel',serif; font-size:18px; font-weight:700; color:var(--text-primary); line-height:1.3;">{{topArtist.title}}</p>
      </div>
      {{/if}}
      {{#if topBook}}
      <div style="flex:1; padding:24px; border:1px solid var(--border); border-radius:16px; background:rgba(18,10,13,0.5);">
        <p style="font-size:11px; font-weight:600; color:var(--text-muted); letter-spacing:0.15em; text-transform:uppercase; margin-bottom:8px;">Top Book</p>
        <p style="font-family:'Cinzel',serif; font-size:18px; font-weight:700; color:var(--text-primary); line-height:1.3;">{{topBook.title}}</p>
      </div>
      {{/if}}
    </div>

    <!-- Share CTA -->
    <div style="margin-top:auto; padding:36px; border:2px solid var(--gold); border-radius:24px; background:rgba(214,184,122,0.08); text-align:center;">
      <p class="font-cinzel" style="font-size:28px; font-weight:700; color:var(--gold); margin-bottom:12px;">Share Your Wrapped</p>
      <p style="font-size:15px; color:var(--text-muted);">Show your friends what you've been enjoying on NaijasPride</p>
    </div>

  </div>

  <div class="watermark-bar">
    naijaspride.com · Thank you for being part of NaijasPride
  </div>
</div>