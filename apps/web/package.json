{
  "name": "web",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "start": "ng serve",
    "build": "ng build --configuration production",
    "build:dev": "ng build --configuration development",
    "build:fast": "ng build --configuration fast",
    "build:dev:mem": "node --max-old-space-size=8192 ./node_modules/@angular/cli/bin/ng build --configuration development",
    "build:fast:mem": "node --max-old-space-size=8192 ./node_modules/@angular/cli/bin/ng build --configuration fast",
    "build:prod:mem": "node --max-old-space-size=8192 ./node_modules/@angular/cli/bin/ng build --configuration production",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "ng lint"
  },
  "dependencies": {
    "@angular-devkit/build-angular": "^17.2.0",
    "@angular/animations": "^17.2.0",
