    "pdfjs-dist": "^5.4.624",
    "rxjs": "~7.8.0",
    "screenfull": "^6.0.2",
    "swiper": "^12.1.0",
    "tslib": "^2.3.0",
    "typescript": "^5.4.0",
    "zone.js": "~0.14.3"
  },
  "devDependencies": {
    "@naijaspride/config": "*",
    "@types/node": "^18.18.0",
    "autoprefixer": "^10.4.18",
    "postcss": "^8.4.35",
