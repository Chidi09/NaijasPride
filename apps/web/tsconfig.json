{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "../../dist/out-tsc",
    "types": ["node"],
    "useDefineForClassFields": false,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true
  },
  "files": [
    "src/main.ts",
    "src/app/app.config.ts",
    "src/main.server.ts",
    "server.ts"
  ],
  "include": ["src/**/*.d.ts", "src/**/*.ts"]
}
