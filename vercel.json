{
  "framework": null,
  "installCommand": "npm ci --legacy-peer-deps",
  "buildCommand": "npm run build:types && npm run build:web",
  "outputDirectory": "apps/web/dist/web/browser",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://naijaspride.pxxl.click/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
